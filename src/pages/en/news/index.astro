---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHero from '../../../components/PageHero.astro';
import ContactCTA from '../../../components/ContactCTA.astro';

const news = [
  {
    date:  '2026/03/13',
    badge: 'Corporate',
    title: 'Launched "BizinTokyo" — a bilingual media platform for business events in Tokyo',
    href:  'https://bizintokyo.com',
    external: true,
  },
  {
    date:  '2025/11/07',
    badge: 'note',
    title: 'Published: "How My Role Changed Moving from Engineer to Executive — LayerX on the AI Era Management Playbook"',
    href:  'https://note.com/firstfollowers/n/n461becdd12b9',
    external: true,
  },
  {
    date:  '2025/10/29',
    badge: 'note',
    title: 'Published: "How Roles Keep Evolving as Startups Grow — Loglass × Luup Co-founders on the CTO Career Path"',
    href:  'https://note.com/firstfollowers/n/n03e8dd67f5b6',
    external: true,
  },
  {
    date:  '2025/10/24',
    badge: 'note',
    title: 'Published: "Making Full Use of Tokyo\'s Startup Support — 5 Steps You Can Start Today"',
    href:  'https://note.com/firstfollowers/n/ne557ec584591',
    external: true,
  },
];

const badgeColors: Record<string, string> = {
  'Corporate': '#1A1AB4',
  'note': '#41c9b4',
  'Blog': '#f59e0b',
  'Case Study': '#6366f1',
};
---

<BaseLayout title="News & Updates" description="News and updates from Conectando Inc. — corporate announcements, press releases, and event information.">

  <PageHero label="NEWS" title="NEWS" />

  <div class="page-wrap">
    <p class="page-lead">News and updates from Conectando.<br>Corporate announcements, press releases, and event information.</p>

    <ul class="news-list">
      {news.map(n => (
        <li class="news-item">
          <a
            href={n.href}
            class="news-link"
            target={n.external ? '_blank' : undefined}
            rel={n.external ? 'noopener' : undefined}
          >
            <time class="news-date">{n.date}</time>
            <span
              class="news-badge"
              style={`background:${badgeColors[n.badge] ?? '#1A1AB4'}`}
            >{n.badge}</span>
            <span class="news-text">{n.title}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <ContactCTA />

</BaseLayout>

<style>
.page-wrap { max-width: 56rem; margin: 0 auto; padding: 0 2rem 5rem; }
.page-lead { color: var(--color-text-muted); line-height: 1.8; font-size: .9375rem; margin: 2rem 0 2.5rem; }
.news-list { list-style: none; padding: 0; margin: 0; }
.news-item { border-bottom: 1px solid #d1d5db; }
.news-item:first-child { border-top: 1px solid #d1d5db; }
.news-link {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: .75rem;
  padding: 1rem 0;
  text-decoration: none;
  color: inherit;
  transition: opacity .15s;
}
.news-link:hover { opacity: .75; }
.news-date { font-size: .8125rem; color: var(--color-text-muted); white-space: nowrap; }
.news-badge { font-size: .6875rem; padding: .1875rem .625rem; color: #fff; border-radius: 9999px; white-space: nowrap; }
.news-text { font-size: .9375rem; color: var(--color-text); line-height: 1.5; }
</style>
