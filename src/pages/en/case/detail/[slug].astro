---
// src/pages/en/case/detail/[slug].astro
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import ContactCTA from '../../../../components/ContactCTA.astro';

export async function getStaticPaths() {
  const cases = [
    {
      slug:     'gatetoindiaafrica',
      title:    'Gate to India & Africa 2024',
      date:     'July 9, 2024',
      service:  'Event Management Support',
      services: ['Planning & Operations', 'Venue Arrangement', 'Session Building', 'Marketing & Promotion', 'Event Website'],
      overview: 'This event was held as part of the official side events of IVS (Infinity Venture Summit), with the aim of deepening connections and cooperation between Japanese companies and startups from Africa and India. It was held in both Kyoto and Tokyo.\n\nThrough networking sessions and panel discussions, we facilitated new business opportunities and the formation of global partnerships.',
      organizers: [
        { label: 'SGgrow Pte Ltd', href: 'https://sggrow.notion.site/SGgrow-Pte-Ltd-1d01610ae4e245de80d850b1bd5fc117' },
        { label: 'Uncovered Fund', href: 'https://uncoveredfund.com/' },
      ],
      website:  'https://gatetoindiaafrica.studio.site',
      scale:    '200 attendees',
      venue:    'Tokyo Innovation Base (TIB)',
      articles: [],
      img:      '/images/about/event-group.webp',
    },
    {
      slug:     'newyorksiliconalley',
      title:    'New York Silicon Alley Meetup #11',
      date:     'May 9, 2024',
      service:  'Event Management Support',
      services: ['Venue Arrangement', 'Layout Design', 'Catering', 'Marketing & Promotion', 'Event Website'],
      overview: '"New York Silicon Alley Meetup" is a special event focused on the New York startup ecosystem. Silicon Alley — the high-tech hub centred on Manhattan — consistently ranks second only to Silicon Valley in global startup rankings.\n\nThis edition marked a return after nearly six years, welcoming investors, entrepreneurs, and supporters active in New York to discuss the latest developments in the NY ecosystem and investment landscape.',
      organizers: [
        { label: 'SQRP NY', href: 'https://sqrpny.com/' },
      ],
      website:  'https://nysiliconalley11.peatix.com/',
      scale:    '100 attendees',
      venue:    'Shibuya Open Innovation Lab (SOIL)',
      articles: [
        { label: 'Event Report (Pilotboat)', href: 'https://pilotboat.jp/en/2024/06/ny-silicon-alley-meetup/' },
      ],
      img:      '/images/about/event-group.webp',
    },
    {
      slug:     'startupdiversityday',
      title:    'Startup Diversity Day',
      date:     'May 14, 2024',
      service:  'Event Management Support',
      services: ['Venue Arrangement', 'Layout Design', 'Session Building', 'Marketing & Promotion', 'Catering', 'Event Website'],
      overview: 'On May 14, 2024, "Tokyo Startup Diversity Day" was held at Google for Startups Campus Tokyo.\n\nOrganised as a side event of SusHiTech Tokyo — a Tokyo Metropolitan Government initiative — this event was designed to explore diversity and the importance of innovation in startups. Hosted by Yazawa Ventures and co-sponsored by Dell Technologies, the event featured in-depth discussions on topics including gender balance, multinational teams, and the intersection of startups and parenting.',
      organizers: [
        { label: 'Yazawa Ventures', href: 'https://yazawa.vc/' },
      ],
      website:  'https://tokyostartupdiversityday.studio.site/',
      scale:    '100 attendees',
      venue:    'Google for Startups Campus Tokyo',
      articles: [],
      img:      '/images/about/event-group.webp',
    },
    {
      slug:     'gatetoindiaafrica2025',
      title:    'Gate to India & Africa 2025',
      date:     'July 7, 2025',
      service:  'Event Management Support',
      services: ['Planning & Operations', 'Venue Arrangement', 'Session Building', 'Marketing & Promotion'],
      overview: 'The 2025 edition of Gate to India & Africa. A networking event connecting Indian and African startups with Japanese companies.',
      organizers: [],
      website:  '',
      scale:    '',
      venue:    'Tokyo Innovation Base (TIB)',
      articles: [],
      img:      '/images/about/event-group.webp',
    },
    {
      slug:     'newyorksiliconalley12',
      title:    'New York Silicon Alley Meetup #12',
      date:     'May 8, 2025',
      service:  'Event Management Support',
      services: ['Venue Arrangement', 'Layout Design', 'Marketing & Promotion'],
      overview: 'The 12th edition of the New York Silicon Alley Meetup series. Bringing the cutting edge of the New York startup ecosystem to Tokyo.',
      organizers: [],
      website:  '',
      scale:    '',
      venue:    'Tokyo',
      articles: [],
      img:      '/images/about/event-group.webp',
    },
    {
      slug:     'indoafrica2025',
      title:    'India & Africa Entrepreneur & Investor Mixer — Feeling the Global South Momentum in Kyoto',
      date:     'July 4, 2025',
      service:  'Event Management Support',
      services: ['Planning & Operations', 'Venue Arrangement', 'Marketing & Promotion'],
      overview: 'A Kyoto side event held during IVS 2025. Indian and African Global South entrepreneurs and investors connect with Japanese participants.',
      organizers: [],
      website:  '',
      scale:    '',
      venue:    'Kyoto',
      articles: [],
      img:      '/images/about/event-group.webp',
    },
  ];

  return cases.map(c => ({
    params: { slug: c.slug },
    props:  { caseData: c },
  }));
}

const { caseData: c } = Astro.props;
---

<BaseLayout title={`${c.title} | Case Study`} description={`Case study: ${c.title} (${c.date}).`}>

  <div class="detail-hero">
    <img src={c.img} alt={c.title} class="hero-img" />
    <div class="hero-overlay">
      <span class="hero-badge">{c.service}</span>
    </div>
  </div>

  <div class="page-wrap">
    <h1 class="detail-h1">{c.title}</h1>
    <p class="detail-date">{c.date}</p>

    <section class="detail-section">
      <h2 class="detail-h2">Services Provided</h2>
      <ul class="tag-list">
        {c.services.map(s => <li class="tag">{s}</li>)}
      </ul>
    </section>

    <section class="detail-section">
      <h2 class="detail-h2">Event Overview</h2>
      {c.overview.split('\n\n').map(p => <p class="detail-body">{p}</p>)}
    </section>

    {c.organizers.length > 0 && (
      <section class="detail-section">
        <h2 class="detail-h2">Organiser</h2>
        <ul class="link-list">
          {c.organizers.map(o => (
            <li><a href={o.href} class="ext-link" target="_blank" rel="noopener">{o.label}</a></li>
          ))}
        </ul>
      </section>
    )}

    {c.website && (
      <section class="detail-section">
        <h2 class="detail-h2">Event Website</h2>
        <a href={c.website} class="ext-link" target="_blank" rel="noopener">{c.website}</a>
      </section>
    )}

    {(c.scale || c.venue) && (
      <section class="detail-section">
        <dl class="meta-dl">
          {c.scale && (
            <>
              <dt>Event Scale</dt>
              <dd>{c.scale}</dd>
            </>
          )}
          {c.venue && (
            <>
              <dt>Venue</dt>
              <dd>{c.venue}</dd>
            </>
          )}
        </dl>
      </section>
    )}

    {c.articles.length > 0 && (
      <section class="detail-section">
        <h2 class="detail-h2">Related Articles</h2>
        <ul class="link-list">
          {c.articles.map(a => (
            <li><a href={a.href} class="ext-link" target="_blank" rel="noopener">{a.label}</a></li>
          ))}
        </ul>
      </section>
    )}

    <div class="back-row">
      <a href="/en/case" class="back-link">← Back to Case Studies</a>
    </div>
  </div>

  <ContactCTA />

</BaseLayout>

<style>
.detail-hero {
  position: relative;
  width: 100%;
  max-height: 360px;
  overflow: hidden;
}
.hero-img { width: 100%; max-height: 360px; object-fit: cover; display: block; }
.hero-overlay {
  position: absolute;
  inset: auto 0 0 0;
  padding: 1.5rem 2rem;
  background: linear-gradient(to top, rgba(0,0,0,.6), transparent);
}
.hero-badge {
  font-size: .75rem;
  padding: .25rem .75rem;
  background: var(--color-brand);
  color: #fff;
  border-radius: 9999px;
}
.page-wrap {
  max-width: 52rem;
  margin: 0 auto;
  padding: 0 2rem 5rem;
}
.detail-h1 {
  font-size: clamp(1.375rem, 3vw, 2rem);
  font-weight: 800;
  color: var(--color-brand);
  margin: 2rem 0 .5rem;
  line-height: 1.35;
}
.detail-date { font-size: .875rem; color: var(--color-text-muted); margin-bottom: 2.5rem; }
.detail-section {
  margin-bottom: 2.5rem;
  padding-bottom: 2.5rem;
  border-bottom: 1px solid #e5e7eb;
}
.detail-h2 {
  font-size: 1rem;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 1rem;
  padding-bottom: .5rem;
  border-bottom: 1px solid #e5e7eb;
}
.detail-body { color: var(--color-text-muted); line-height: 1.9; font-size: .9375rem; margin-bottom: 1rem; }
.detail-body:last-child { margin-bottom: 0; }
.tag-list { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: .5rem; }
.tag {
  font-size: .8125rem;
  padding: .3125rem .875rem;
  background: var(--color-accent);
  color: var(--color-brand);
  border: 1px solid #c7c7f5;
  border-radius: 9999px;
  font-weight: 600;
}
.link-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: .5rem; }
.ext-link { color: var(--color-brand); font-size: .9375rem; text-decoration: underline; word-break: break-all; }
.ext-link:hover { opacity: .75; }
.meta-dl { display: grid; grid-template-columns: 8rem 1fr; gap: .75rem 1rem; font-size: .9375rem; }
.meta-dl dt { font-weight: 700; color: var(--color-text); }
.meta-dl dd { color: var(--color-text-muted); }
.back-row { margin-top: 1rem; }
.back-link { font-size: .9375rem; color: var(--color-brand); font-weight: 600; text-decoration: none; }
.back-link:hover { opacity: .75; }
</style>
