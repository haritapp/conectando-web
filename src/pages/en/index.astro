---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Bilingual Event Planning in Tokyo" description="Conectando Inc. — Bilingual event planning & management in Tokyo. Total support for international companies, startups, and Web3 events.">
  <section style="background: var(--color-brand); color: white; padding: 6rem 2rem; text-align: center;">
    <h1 style="font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 700; margin-bottom: 1.5rem; line-height: 1.2;">
      Connecting Tokyo<br />through Bilingual Events.
    </h1>
    <p style="font-size: 1.25rem; opacity: 0.85; margin-bottom: 2.5rem; max-width: 600px; margin-inline: auto;">
      Full-service bilingual event planning & management for international companies, startups, and Web3 organizations in Tokyo.
    </p>
    <a href="/en/contact" style="display: inline-block; background: white; color: var(--color-brand); font-weight: 700; padding: 1rem 2.5rem; border-radius: 8px; font-size: 1.1rem;">
      Get in Touch
    </a>
  </section>

  <section style="max-width: 1100px; margin: 5rem auto; padding: 0 2rem;">
    <h2 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 3rem; text-align: center;">Services</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem;">
      <div style="border: 1px solid var(--color-border); border-radius: 12px; padding: 2rem;">
        <h3 style="font-weight: 700; margin-bottom: 0.75rem; color: var(--color-brand);">Event Planning & Management</h3>
        <p style="color: var(--color-text-muted); line-height: 1.7;">Full support from venue selection to on-site management.</p>
      </div>
      <div style="border: 1px solid var(--color-border); border-radius: 12px; padding: 2rem;">
        <h3 style="font-weight: 700; margin-bottom: 0.75rem; color: var(--color-brand);">Bilingual Support</h3>
        <p style="color: var(--color-text-muted); line-height: 1.7;">Our bilingual staff bridges international organizers with Tokyo's event ecosystem.</p>
      </div>
      <div style="border: 1px solid var(--color-border); border-radius: 12px; padding: 2rem;">
        <h3 style="font-weight: 700; margin-bottom: 0.75rem; color: var(--color-brand);">Tours & Matchmaking</h3>
        <p style="color: var(--color-text-muted); line-height: 1.7;">Startup & investor tours, and matchmaking events in Japan.</p>
      </div>
    </div>
  </section>
</BaseLayout>
