---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactCTA from '../../components/ContactCTA.astro';

// ── Stub data (migrate to CMS/Content Collections later) ──
const caseSlides = [
  { title: 'Gate to India & Africa',   badge: 'Event Case', href: '/en/case/detail/gatetoindiaafrica',   bg: '#1a237e' },
  { title: 'New York Silicon Alley',   badge: 'Event Case', href: '/en/case/detail/newyorksiliconalley', bg: '#0d47a1' },
  { title: 'SushiTech Tokyo',          badge: 'Column',     href: 'https://bizintokyo.com/en/column/sushitech_column', bg: '#1b5e20' },
  { title: 'Startup Diversity Day',    badge: 'Event Case', href: '/en/case/detail/startupdiversityday', bg: '#4a148c' },
];

const services = [
  {
    title: 'Event Management Support',
    desc:  'We provide one-stop support for the operation of events, mainly for startups and Web3 events. Since we can offer support in English, overseas organizers can also hold events with confidence.',
    href:  '/en/service#service-1',
    img:   'https://images.unsplash.com/photo-1511578314322-379afb476865?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=480',
  },
  {
    title: 'Media Operations',
    desc:  'Through our bilingual media "BizinTokyo," we support event promotion and information dissemination.',
    href:  '/en/service#service-4',
    img:   'https://storage.stock.studio.design/optimized/ZQ41L1OlPx7nbUqIEWpez.webp',
  },
  {
    title: 'Japan Tours',
    desc:  'We organize Japan tours that facilitate business matching through site visits and event participation.',
    href:  '/en/service#service-2',
    img:   '/images/about/sakura-fuji.jpg',
  },
  {
    title: 'Japan Entry Support',
    desc:  'We provide comprehensive support for entering the Japanese market, from market research to recruitment support and office search.',
    href:  '/en/service',
    img:   'https://storage.stock.studio.design/optimized/2nmh0zT5szPfjE4lrwQXm.webp',
  },
];

const cases = [
  { title: 'Gate to India & Africa', href: '/en/case/detail/gatetoindiaafrica',   img: '/images/about/event-group.webp' },
  { title: 'New York Silicon Alley', href: '/en/case/detail/newyorksiliconalley', img: '/images/about/event-group.webp' },
  { title: 'Startup Diversity Day',  href: '/en/case/detail/startupdiversityday', img: '/images/about/event-group.webp' },
];

const blogs = [
  {
    date:  '2024/10/7',
    title: '4 Key Considerations for Foreign Company Japan Representatives When Hosting Events in Japan',
    href:  '/en/blog',
    img:   'https://images.unsplash.com/photo-1521737604893-d14cc237f11d?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=500',
  },
  {
    date:  '2024/9/19',
    title: 'The One Key Point for English-Speaking Organizers to Successfully Run Events in Japan',
    href:  '/en/blog',
    img:   'https://images.unsplash.com/photo-1540575467063-178a50c2df87?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=500',
  },
];

const news = [
  {
    date:  '2025/10/29',
    badge: 'note',
    title: 'Published: "How My Role Changed Moving from Engineer to Executive — LayerX on the AI Era Management Playbook"',
    href:  '/en/news',
  },
];
---

<BaseLayout title="Conectando Inc. | Bilingual Event Management in Tokyo" description="Conectando connects global networks to support Japan's business growth — event management, media, Japan tours, and market entry support.">

  <!-- ① Hero -->
  <section class="top-hero">
    <h1 class="hero-h1">Connecting Networks<br>Boosting Japan</h1>
  </section>

  <!-- ② Case Slider -->
  <div class="slider-wrap">
    <ul class="slider-track" role="list">
      {caseSlides.map(s => (
        <li>
          <a href={s.href} class="slide-card" style={`--bg:${s.bg}`}>
            <div class="slide-bg"></div>
            <div class="slide-overlay">
              <span class="slide-badge">{s.badge}</span>
              <span class="slide-title">{s.title}</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <!-- ③ About Preview -->
  <section class="about-sec">
    <div class="dot-rule"></div>
    <div class="sec-body">
      <h2 class="about-h2">Connecting Networks<br>Boosting Japan</h2>
      <p class="about-p">
        We leverage our global network to support Japanese businesses, connecting overseas companies with local partners to create new growth opportunities.
      </p>
      <p class="about-p" style="margin-top:1rem">
        As we assist with market entry, we offer practical advice to navigate cultural differences and business practices. Our mission is to strengthen networks and enhance Japan's competitiveness.
      </p>
      <a href="/en/about" class="pill-btn" style="display:inline-flex;margin-top:2rem">
        View Detail <span class="btn-dot">●</span>
      </a>
    </div>
  </section>

  <!-- ④ Services -->
  <section class="svc-sec">
    <div class="dot-rule"></div>
    <div class="sec-body">
      <ul class="svc-list" role="list">
        {services.map(s => (
          <li class="svc-item">
            <a href={s.href} class="svc-link">
              <img src={s.img} alt={s.title} class="svc-img" loading="lazy" />
              <div>
                <h3 class="svc-title">{s.title}</h3>
                <p class="svc-desc">{s.desc}</p>
              </div>
            </a>
          </li>
        ))}
      </ul>
      <div class="right-cta">
        <a href="/en/service" class="text-cta">View All <span class="btn-dot">●</span></a>
      </div>
    </div>
  </section>

  <!-- ⑤ Case Studies Grid -->
  <section class="cases-sec">
    <div class="dot-rule"></div>
    <div class="sec-body">
      <div class="case-grid">
        {cases.map(c => (
          <a href={c.href} class="case-card">
            <img src={c.img} alt={c.title} class="case-img" loading="lazy" />
          </a>
        ))}
      </div>
      <div class="right-cta">
        <a href="/en/case" class="text-cta">View All <span class="btn-dot">●</span></a>
      </div>
    </div>
  </section>

  <!-- ⑥ Blog -->
  <section class="blog-sec">
    <div class="dot-rule"></div>
    <div class="sec-body">
      <div class="blog-grid">
        {blogs.map(b => (
          <a href={b.href} class="blog-card">
            <img src={b.img} alt={b.title} class="blog-img" loading="lazy" />
            <div class="blog-meta">
              <time class="blog-date">{b.date}</time>
              <p class="blog-title">{b.title}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="right-cta">
        <a href="/en/blog" class="text-cta">View All <span class="btn-dot">●</span></a>
      </div>
    </div>
  </section>

  <!-- ⑦ News -->
  <section class="news-sec">
    <div class="dot-rule"></div>
    <div class="sec-body">
      <ul class="news-list" role="list">
        {news.map(n => (
          <li class="news-item">
            <a href={n.href} class="news-link">
              <time class="news-date">{n.date}</time>
              <span class="news-badge">{n.badge}</span>
              <span class="news-text">{n.title}</span>
            </a>
          </li>
        ))}
      </ul>
      <div class="right-cta">
        <a href="/en/news" class="text-cta">View All <span class="btn-dot">●</span></a>
      </div>
    </div>
  </section>

  <ContactCTA />

</BaseLayout>

<style>
/* ─── Hero ─── */
.top-hero {
  max-width: 80rem;
  margin: 0 auto;
  padding: 5rem 2rem 3rem;
}
.hero-h1 {
  font-size: clamp(2.75rem, 6vw, 5.5rem);
  font-weight: 900;
  line-height: 1.1;
  color: var(--color-text);
  letter-spacing: -0.02em;
  margin-bottom: 1.25rem;
}

/* ─── Slider ─── */
.slider-wrap {
  overflow-x: auto;
  padding: 0 2rem 2.5rem;
  scrollbar-width: none;
}
.slider-wrap::-webkit-scrollbar { display: none; }
.slider-track {
  display: flex;
  gap: 1rem;
  list-style: none;
  padding: 0;
  margin: 0;
  width: max-content;
}
.slide-card {
  position: relative;
  display: block;
  width: 260px;
  height: 200px;
  border-radius: .5rem;
  overflow: hidden;
  text-decoration: none;
}
.slide-bg { width: 100%; height: 100%; background: var(--bg, #1a237e); }
.slide-overlay {
  position: absolute;
  inset: auto 0 0 0;
  padding: .75rem 1rem;
  background: linear-gradient(to top, rgba(0,0,0,.75), transparent);
  color: #fff;
  display: flex;
  flex-direction: column;
  gap: .2rem;
}
.slide-badge { font-size: .6875rem; opacity: .85; }
.slide-title  { font-size: .875rem; font-weight: 700; line-height: 1.3; }

/* ─── Dot rule ─── */
.dot-rule {
  display: flex;
  align-items: center;
  padding: 0 2rem;
  margin-bottom: 2rem;
}
.dot-rule::before {
  content: '';
  width: 10px; height: 10px;
  border-radius: 50%;
  background: var(--color-brand);
  flex-shrink: 0;
  margin-right: .5rem;
}
.dot-rule::after {
  content: '';
  flex: 1;
  height: 1px;
  background: #d1d5db;
}

/* ─── Section body ─── */
.sec-body {
  max-width: 80rem;
  margin: 0 auto;
  padding: 0 2rem 4rem;
}

/* ─── About ─── */
.about-sec { background: var(--color-accent); padding-top: 3rem; }
.about-h2 {
  font-size: clamp(1.625rem, 3.5vw, 2.75rem);
  font-weight: 800;
  color: var(--color-brand);
  line-height: 1.35;
  margin-bottom: 1.5rem;
}
.about-p {
  color: var(--color-text-muted);
  line-height: 1.85;
  max-width: 42rem;
  font-size: .9375rem;
}
.pill-btn {
  align-items: center;
  gap: .5rem;
  background: var(--color-brand);
  color: #fff;
  padding: .75rem 1.75rem;
  border-radius: 9999px;
  font-weight: 600;
  font-size: .9375rem;
  text-decoration: none;
  transition: opacity .2s;
}
.pill-btn:hover { opacity: .85; }
.btn-dot { font-size: .55em; }

/* ─── Services ─── */
.svc-sec { padding-top: 3rem; }
.svc-list { list-style: none; padding: 0; margin: 0; }
.svc-item { border-bottom: 1px solid #e5e7eb; }
.svc-item:first-child { border-top: 1px solid #e5e7eb; }
.svc-link {
  display: flex;
  align-items: flex-start;
  gap: 1.5rem;
  padding: 1.5rem 0;
  text-decoration: none;
  color: inherit;
}
.svc-img {
  width: 180px; height: 120px;
  object-fit: cover;
  border-radius: .375rem;
  flex-shrink: 0;
}
.svc-title {
  font-size: 1.125rem;
  font-weight: 700;
  color: var(--color-brand);
  margin-bottom: .5rem;
}
.svc-desc {
  font-size: .9375rem;
  color: var(--color-text-muted);
  line-height: 1.7;
}

/* ─── Right CTA ─── */
.right-cta { display: flex; justify-content: flex-end; margin-top: 1.5rem; }
.text-cta {
  display: inline-flex;
  align-items: center;
  gap: .375rem;
  color: var(--color-brand);
  font-weight: 700;
  font-size: .9375rem;
  text-decoration: none;
}
.text-cta:hover { opacity: .75; }

/* ─── Cases ─── */
.cases-sec { background: var(--color-accent); padding-top: 3rem; }
.case-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
.case-card { display: block; border-radius: .5rem; overflow: hidden; text-decoration: none; }
.case-img { width: 100%; aspect-ratio: 3/2; object-fit: cover; display: block; }

/* ─── Blog ─── */
.blog-sec { padding-top: 3rem; }
.blog-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
.blog-card { display: block; text-decoration: none; color: inherit; }
.blog-img {
  width: 100%; aspect-ratio: 4/3;
  object-fit: cover;
  border-radius: .375rem;
  margin-bottom: .75rem;
  display: block;
}
.blog-meta { padding: 0 .125rem; }
.blog-date  { display: block; font-size: .8125rem; color: var(--color-text-muted); margin-bottom: .375rem; }
.blog-title { font-size: .9375rem; font-weight: 600; color: var(--color-brand); line-height: 1.5; }

/* ─── News ─── */
.news-sec { background: var(--color-accent); padding-top: 3rem; }
.news-list { list-style: none; padding: 0; margin: 0; }
.news-item { border-bottom: 1px solid #d1d5db; }
.news-item:first-child { border-top: 1px solid #d1d5db; }
.news-link {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: .75rem;
  padding: 1rem 0;
  text-decoration: none;
  color: inherit;
}
.news-date  { font-size: .8125rem; color: var(--color-text-muted); white-space: nowrap; }
.news-badge {
  font-size: .6875rem;
  padding: .1875rem .625rem;
  background: var(--color-brand);
  color: #fff;
  border-radius: 9999px;
  white-space: nowrap;
}
.news-text { font-size: .9375rem; color: var(--color-text); line-height: 1.5; }
</style>
