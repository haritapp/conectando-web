---
// src/pages/case/detail/[slug].astro
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ContactCTA from '../../../components/ContactCTA.astro';

export async function getStaticPaths() {
  const cases = [
    {
      slug:     'gatetoindiaafrica',
      title:    'Gate to India & Africa 2024',
      date:     '2024年7月9日開催',
      service:  'イベント運営支援',
      services: ['企画・運営', '会場手配', 'セッション構築', '集客・プロモーション', 'イベントサイト制作'],
      overview: 'このイベントは、IVS（Infinity Venture Summit）の公式サイドイベントの一環で、日本企業とアフリカ、インドのスタートアップの間でのつながりと協力を深めることを目指し、京都と東京で開催されました。\n\nネットワーキングおよびセッションを通じて、新たなビジネスチャンスとグローバルパートナーシップの構築を支援しました。',
      organizers: [
        { label: 'SGgrow Pte Ltd', href: 'https://sggrow.notion.site/SGgrow-Pte-Ltd-1d01610ae4e245de80d850b1bd5fc117' },
        { label: 'Uncovered Fund', href: 'https://uncoveredfund.com/' },
      ],
      website:  'https://gatetoindiaafrica.studio.site',
      scale:    '200名',
      venue:    'Tokyo Innovation Base (TIB)',
      articles: [],
      img:      '/images/about/event-group.webp',
    },
    {
      slug:     'newyorksiliconalley',
      title:    'New York Silicon Alley Meetup #11',
      date:     '2024年5月9日開催',
      service:  'イベント運営支援',
      services: ['会場手配', 'レイアウト設計', 'ケータリング手配', '集客・プロモーション', 'イベントサイト制作'],
      overview: '「New York Silicon Alley Meetup」は、ニューヨークのスタートアップエコシステムに焦点を当てた特別イベントです。シリコンアレー（Silicon Alley）は、マンハッタンを中心としたニューヨーク都市圏に広がるハイテク産業の集積地であり、世界のスタートアップランキングではシリコンバレーに次ぐ位置を常に維持しています。\n\n今回のイベントは、約6年ぶりの開催となり、ニューヨークで活躍する投資家、起業家、支援者たちをゲストに迎え、シリコンバレーを超えるマーケットの強みを持つニューヨークの最新エコシステムと投資環境について語り合いました。',
      organizers: [
        { label: 'SQRP NY', href: 'https://sqrpny.com/' },
      ],
      website:  'https://nysiliconalley11.peatix.com/',
      scale:    '100名',
      venue:    'Shibuya Open Innovation Lab（SOIL）',
      articles: [
        { label: 'イベントレポート（Pilotboat）', href: 'https://pilotboat.jp/en/2024/06/ny-silicon-alley-meetup/' },
      ],
      img:      '/images/about/event-group.webp',
    },
    {
      slug:     'startupdiversityday',
      title:    'Startup Diversity Day',
      date:     '2024年5月14日開催',
      service:  'イベント運営支援',
      services: ['会場手配', 'レイアウト設計', 'セッション構築', '集客・プロモーション', 'ケータリング手配', 'イベントサイト制作'],
      overview: '2024年5月14日、「Tokyo Startup Diversity Day」がGoogle for Startups Campus Tokyoにて開催されました。\n\nこのイベントは、東京都主催のSusHiTech Tokyoのサイドイベントとして、多様性（ダイバーシティ）とスタートアップにおけるイノベーションの重要性を探るために企画されました。Yazawa Venturesが主催し、デル・テクノロジーズ株式会社の協賛のもと、ジェンダーバランスや多国籍チーム、スタートアップと育児など、多様性のテーマに関する深い議論が行われました。',
      organizers: [
        { label: 'Yazawa Ventures', href: 'https://yazawa.vc/' },
      ],
      website:  'https://tokyostartupdiversityday.studio.site/',
      scale:    '100名',
      venue:    'Google for Startups Campus Tokyo',
      articles: [],
      img:      '/images/about/event-group.webp',
    },
    {
      slug:     'gatetoindiaafrica2025',
      title:    'Gate to India & Africa 2025',
      date:     '2025年7月7日開催',
      service:  'イベント運営支援',
      services: ['企画・運営', '会場手配', 'セッション構築', '集客・プロモーション'],
      overview: 'Gate to India & Africa の2025年版。インドとアフリカのスタートアップと日本企業をつなぐネットワーキングイベント。',
      organizers: [],
      website:  '',
      scale:    '',
      venue:    'Tokyo Innovation Base (TIB)',
      articles: [],
      img:      '/images/about/event-group.webp',
    },
    {
      slug:     'newyorksiliconalley12',
      title:    'New York Silicon Alley Meetup #12',
      date:     '2025年5月8日開催',
      service:  'イベント運営支援',
      services: ['会場手配', 'レイアウト設計', '集客・プロモーション'],
      overview: 'New York Silicon Alley Meetup シリーズ第12回。ニューヨークのスタートアップエコシステムの最前線を東京で紹介。',
      organizers: [],
      website:  '',
      scale:    '',
      venue:    '東京都内',
      articles: [],
      img:      '/images/about/event-group.webp',
    },
    {
      slug:     'indoafrica2025',
      title:    '【インド・アフリカ】起業家・投資家交流会 〜京都で感じるグローバルサウスの勢い〜',
      date:     '2025年7月4日開催',
      service:  'イベント運営支援',
      services: ['企画・運営', '会場手配', '集客・プロモーション'],
      overview: 'IVS 2025開催期間中の京都サイドイベント。インドとアフリカのグローバルサウス起業家・投資家と日本の参加者が交流。',
      organizers: [],
      website:  '',
      scale:    '',
      venue:    '京都',
      articles: [],
      img:      '/images/about/event-group.webp',
    },
  ];

  return cases.map(c => ({
    params: { slug: c.slug },
    props:  { caseData: c },
  }));
}

const { caseData: c } = Astro.props;
---

<BaseLayout title={`${c.title} | 導入事例`} description={`${c.title}（${c.date}）の導入事例をご紹介します。`}>

  <div class="detail-hero">
    <img src={c.img} alt={c.title} class="hero-img" />
    <div class="hero-overlay">
      <span class="hero-badge">{c.service}</span>
    </div>
  </div>

  <div class="page-wrap">
    <h1 class="detail-h1">{c.title}</h1>
    <p class="detail-date">{c.date}</p>

    <section class="detail-section">
      <h2 class="detail-h2">ご利用いただいたサービス</h2>
      <ul class="tag-list">
        {c.services.map(s => <li class="tag">{s}</li>)}
      </ul>
    </section>

    <section class="detail-section">
      <h2 class="detail-h2">イベント概要</h2>
      {c.overview.split('\n\n').map(p => <p class="detail-body">{p}</p>)}
    </section>

    {c.organizers.length > 0 && (
      <section class="detail-section">
        <h2 class="detail-h2">主催</h2>
        <ul class="link-list">
          {c.organizers.map(o => (
            <li><a href={o.href} class="ext-link" target="_blank" rel="noopener">{o.label}</a></li>
          ))}
        </ul>
      </section>
    )}

    {c.website && (
      <section class="detail-section">
        <h2 class="detail-h2">イベントサイト</h2>
        <a href={c.website} class="ext-link" target="_blank" rel="noopener">{c.website}</a>
      </section>
    )}

    {(c.scale || c.venue) && (
      <section class="detail-section">
        <dl class="meta-dl">
          {c.scale && (
            <>
              <dt>イベント規模</dt>
              <dd>{c.scale}</dd>
            </>
          )}
          {c.venue && (
            <>
              <dt>開催場所</dt>
              <dd>{c.venue}</dd>
            </>
          )}
        </dl>
      </section>
    )}

    {c.articles.length > 0 && (
      <section class="detail-section">
        <h2 class="detail-h2">イベントについての記事</h2>
        <ul class="link-list">
          {c.articles.map(a => (
            <li><a href={a.href} class="ext-link" target="_blank" rel="noopener">{a.label}</a></li>
          ))}
        </ul>
      </section>
    )}

    <div class="back-row">
      <a href="/case" class="back-link">← 一覧に戻る</a>
    </div>
  </div>

  <ContactCTA />

</BaseLayout>

<style>
/* ── Hero ── */
.detail-hero {
  position: relative;
  width: 100%;
  max-height: 360px;
  overflow: hidden;
}
.hero-img {
  width: 100%;
  max-height: 360px;
  object-fit: cover;
  display: block;
}
.hero-overlay {
  position: absolute;
  inset: auto 0 0 0;
  padding: 1.5rem 2rem;
  background: linear-gradient(to top, rgba(0,0,0,.6), transparent);
}
.hero-badge {
  font-size: .75rem;
  padding: .25rem .75rem;
  background: var(--color-brand);
  color: #fff;
  border-radius: 9999px;
}

/* ── Content ── */
.page-wrap {
  max-width: 52rem;
  margin: 0 auto;
  padding: 0 2rem 5rem;
}
.detail-h1 {
  font-size: clamp(1.375rem, 3vw, 2rem);
  font-weight: 800;
  color: var(--color-brand);
  margin: 2rem 0 .5rem;
  line-height: 1.35;
}
.detail-date {
  font-size: .875rem;
  color: var(--color-text-muted);
  margin-bottom: 2.5rem;
}
.detail-section {
  margin-bottom: 2.5rem;
  padding-bottom: 2.5rem;
  border-bottom: 1px solid #e5e7eb;
}
.detail-h2 {
  font-size: 1rem;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 1rem;
  padding-bottom: .5rem;
  border-bottom: 1px solid #e5e7eb;
}
.detail-body {
  color: var(--color-text-muted);
  line-height: 1.9;
  font-size: .9375rem;
  margin-bottom: 1rem;
}
.detail-body:last-child { margin-bottom: 0; }

/* ── Tags ── */
.tag-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-wrap: wrap;
  gap: .5rem;
}
.tag {
  font-size: .8125rem;
  padding: .3125rem .875rem;
  background: var(--color-accent);
  color: var(--color-brand);
  border: 1px solid #c7c7f5;
  border-radius: 9999px;
  font-weight: 600;
}

/* ── Links ── */
.link-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: .5rem; }
.ext-link {
  color: var(--color-brand);
  font-size: .9375rem;
  text-decoration: underline;
  word-break: break-all;
}
.ext-link:hover { opacity: .75; }

/* ── Meta DL ── */
.meta-dl {
  display: grid;
  grid-template-columns: 8rem 1fr;
  gap: .75rem 1rem;
  font-size: .9375rem;
}
.meta-dl dt { font-weight: 700; color: var(--color-text); }
.meta-dl dd { color: var(--color-text-muted); }

/* ── Back ── */
.back-row { margin-top: 1rem; }
.back-link {
  font-size: .9375rem;
  color: var(--color-brand);
  font-weight: 600;
  text-decoration: none;
}
.back-link:hover { opacity: .75; }
</style>
