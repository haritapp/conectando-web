---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<section
  class="relative flex items-center justify-center overflow-hidden"
  style="min-height: 260px; background: var(--color-accent);"
>
  <div class="text-center px-4">
    <!-- Small label above -->
    <p
      class="text-xs font-bold tracking-widest uppercase mb-3"
      style="color: var(--color-brand);"
    >
      {title}
    </p>

    <!-- Large display title with bullet dot -->
    <div class="flex items-center justify-center gap-3">
      <span
        class="inline-block rounded-full"
        style="width: 10px; height: 10px; background: var(--color-brand); flex-shrink: 0;"
      ></span>
      <h1
        class="text-5xl sm:text-6xl md:text-7xl font-black tracking-tight"
        style="color: var(--color-brand); line-height: 1;"
      >
        {title}
      </h1>
    </div>
  </div>
</section>

