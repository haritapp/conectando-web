---
interface Item {
  label: string;
  href: string;
}
interface Props {
  items: Item[];
}
const { items } = Astro.props;
---

<nav class="py-8" aria-label="Page sections">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <ul class="flex flex-col sm:flex-row items-stretch sm:items-center justify-center gap-4">
      {items.map((item) => (
        <li class="flex-1 sm:max-w-xs">
          <a
            href={item.href}
            class="flex items-center justify-between gap-2 px-5 py-3 rounded-full border text-sm font-semibold transition-all hover:opacity-80 group"
            style="border-color: var(--color-brand); color: var(--color-brand); text-decoration: none;"
          >
            <span class="flex items-center gap-2">
              <span
                class="inline-block rounded-full flex-shrink-0"
                style="width: 7px; height: 7px; background: var(--color-brand);"
              ></span>
              {item.label}
            </span>
            <!-- arrow_downward icon (inline SVG) -->
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              class="flex-shrink-0"
            >
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <polyline points="19 12 12 19 5 12"></polyline>
            </svg>
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

