---
interface Props {
  text: string;
  buttonText: string;
  href: string;
}
const { text, buttonText, href } = Astro.props;
---

<section style="background: #2d2d2d;">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
    <!-- Section label -->
    <div class="flex items-center justify-center gap-3 mb-6">
      <span
        class="inline-block rounded-full"
        style="width: 8px; height: 8px; background: white; flex-shrink: 0;"
      ></span>
      <p class="text-xs font-bold tracking-widest uppercase text-white">CONTACT</p>
    </div>

    <p class="text-white text-lg md:text-xl mb-8 max-w-xl mx-auto leading-relaxed">
      {text}
    </p>

    <a
      href={href}
      class="inline-block px-10 py-4 text-sm font-bold rounded-full transition-all hover:opacity-80"
      style="background: var(--color-brand); color: white; text-decoration: none;"
    >
      {buttonText}
    </a>
  </div>
</section>

